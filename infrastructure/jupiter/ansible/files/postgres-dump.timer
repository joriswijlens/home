[Unit]
Description=Run Postgres dump every 4 hours (5 min before opencloud-backup)

[Timer]
# Aligned with opencloud-backup.timer (every 4h). Fires 5 minutes earlier so a
# fresh dump exists in /var/lib/postgres-dumps before the rclone sync runs.
OnBootSec=5min
OnUnitActiveSec=4h
AccuracySec=1min
Persistent=true

[Install]
WantedBy=timers.target
