# Copy to .env on Jupiter (next to docker-compose.yml). Do NOT commit .env.
# Generate strong passwords, e.g.: openssl rand -base64 32

# Shared Postgres superuser password.
POSTGRES_PASSWORD=

# Password for the `paperclip` role (used by Paperclip to connect to its DB).
# Read by the postgres init script on first start AND by the paperclip service
# to construct DATABASE_URL — must match.
PAPERCLIP_DB_PASSWORD=

# Master secret for better-auth (Paperclip's auth subsystem). 32+ random bytes.
# REQUIRED in PAPERCLIP_DEPLOYMENT_MODE=authenticated.
BETTER_AUTH_SECRET=

# Optional: pin a specific Paperclip image. Leave unset to use the default in
# docker-compose.yml (ghcr.io/paperclipai/paperclip:latest).
# PAPERCLIP_IMAGE=ghcr.io/paperclipai/paperclip:latest

# Optional: override Paperclip listen port. Default: 4280.
# PAPERCLIP_PORT=4280
